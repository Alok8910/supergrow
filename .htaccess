RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
RewriteRule ^([a-zA-Z0-9-_/]+)$ index.php [QSA]
RewriteRule ^app/views/ - [R=404,L]
RewriteRule ^app/controllers/ - [R=404,L]
RewriteRule ^app/helpers/ - [R=404,L]
Options -Indexes
<FilesMatch "\.(rar|zip|tar|twig)">
Order deny,allow
Deny from all 
</FilesMatch>
